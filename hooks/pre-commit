#!/usr/bin/env python3
"""
Git pre-commit hook.
Install: cp hooks/pre-commit .git/hooks/pre-commit
"""
import subprocess
import sys
import os

repo_root = subprocess.check_output(
    ["git", "rev-parse", "--show-toplevel"], text=True
).strip()
sys.path.insert(0, os.path.join(repo_root, "src"))

from no_leaks.core import run_scan

result = subprocess.run(
    ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
    capture_output=True, text=True
)
staged_files = [f for f in result.stdout.splitlines() if f]

if not staged_files:
    print("SECRET SCANNER: No staged files, skipping.")
    sys.exit(0)

run_scan(staged_files)
